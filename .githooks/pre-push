#!/bin/bash

echo "Running pre-push tests and linting..."

# Run tests
cargo test --workspace
if [ $? -ne 0 ]; then
    echo "Tests failed! Push aborted."
    exit 1
fi

# Run clippy
cargo clippy --workspace -- -D warnings
if [ $? -ne 0 ]; then
    echo "Clippy found issues! Push aborted."
    exit 1
fi

echo "Pre-push checks passed. Proceeding with push."
exit 0
